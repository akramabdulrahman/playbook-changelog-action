{
  "name": "playbook-changelog-action",
  "version": "1.1.6",
  "description": "Self-maintaining playbook and changelog: every PR previews its documentation impact, every merge applies it.",
  "bin": {
    "playbook-install": "scripts/install.js"
  },
  "scripts": {
    "test": "node --test test/unit.test.js test/docs.test.js",
    "test:e2e": "test/simulate.sh mock"
  },
  "files": [
    "action.yml",
    "scripts",
    "templates",
    "examples",
    "docs"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akramabdulrahman/playbook-changelog-action.git"
  }
}
